  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "license": "${mod_license}",
  "environment": "client",
  "entrypoints": {
    "client": [
      "me.noramibu.lumentooltips.fabric.FabricLumenTooltips"
